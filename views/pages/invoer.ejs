<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title %> | <%= appName %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#005bbb">
</head>
<body>
  <%- include('../partials/_header') %>

  <main class="page-shell">
    <section class="content-card">
      <p class="eyebrow"><%= page.eyebrow %></p>
      <h1><%= page.heading %></h1>
      <p><%= page.intro %></p>
      
      <form id="health-form" class="health-form">
        <div class="form-field">
          <label for="date"><%= page.date %></label>
          <input type="date" id="date" required>
        </div>
        <div class="form-field">
          <label for="category"><%= page.category %></label>
          <select id="category" required>
            <option value=""><%= page.chooseCategory %></option>
            <option value="voeding"><%= page.categories.voeding %></option>
            <option value="conditie"><%= page.categories.conditie %></option>
            <option value="slaap"><%= page.categories.slaap %></option>
          </select>
        </div>
        <div class="form-field">
          <label for="description"><%= page.description %></label>
          <input type="text" id="description" placeholder="<%= page.descriptionPlaceholder %>" required>
        </div>
        <div class="form-field">
          <label for="value"><%= page.value %></label>
          <input type="number" id="value" step="any" required>
        </div>
        <button type="submit" class="button button-primary"><%= page.submit %></button>
      </form>

    </section>
  </main>
  <script src="/js/header.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
