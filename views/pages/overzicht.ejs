<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title %> | <%= appName %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#005bbb">
</head>
<body>
  <%- include('../partials/_header') %>

  <main class="page-shell">
    <section class="content-card">
      <p class="eyebrow">Pagina 3</p>
      <h1><%= page.heading %></h1>
      <p><%= page.intro %></p>

      <div class="filter-controls">
        <button class="button button-secondary" data-period="day"><%= page.periodButtons.day %></button>
        <button class="button button-secondary" data-period="week"><%= page.periodButtons.week %></button>
        <button class="button button-secondary" data-period="month"><%= page.periodButtons.month %></button>
      </div>

      <div id="data-container">
        <p><%= page.emptyState %></p>
      </div>

      <div class="stat-grid">
        <article class="stat-card">
          <strong id="item-count">0</strong>
          <span><%= page.savedActivities %></span>
        </article>
        <article class="stat-card">
          <strong id="total-value">0</strong>
          <span id="total-value-label"><%= page.totalLabel.replace('{period}', page.noFilter) %></span>
        </article>
      </div>
    </section>
  </main>
  <script src="/js/header.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
